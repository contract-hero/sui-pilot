.gitignore
.claude/
.remember/
.claude-pr-review/

# Binary assets — useless for AI text consumption
*.jpg
*.jpeg
*.gif
*.svg
*.excalidraw

# Exception: mascot image for README
!sui-pilot.jpg

# Node.js
node_modules/
dist/
*.log
.pnpm-debug.log*

# Ship the prebuilt MCP bundles so marketplace installs work without a
# post-install build step. One un-ignore line per packaged MCP.
!mcp/move-lsp-mcp/dist/
!mcp/move-lsp-mcp/dist/**
!mcp/sui-prover-mcp/dist/
!mcp/sui-prover-mcp/dist/**

# Build artifacts
*.tsbuildinfo

# Bundled docs snapshot produced by scripts/sync-sui-pilot-docs.sh.
# Only docs/VERSION.json is tracked; the rest is regenerated on demand.
docs/*
!docs/VERSION.json
!docs/.gitkeep

# Eval run outputs — produced by evals/run-comparison.sh, not source-controlled.
evals/results/

# GitHub Pages staging directory — assembled by the pages.yml workflow.
_site/

# Sui Move build artifacts inside eval and MCP test fixtures
evals/fixtures/**/build/
evals/fixtures/**/Move.lock
mcp/sui-prover-mcp/test/fixtures/**/build/
mcp/sui-prover-mcp/test/fixtures/**/Move.lock

# Stray sui-prover debug logs that the binary drops in cwd
sui-prover.log.*
